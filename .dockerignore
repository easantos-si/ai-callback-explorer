# Build context root for both backend/Dockerfile and frontend/Dockerfile.
# `.env` is NOT copied into any image — it is read at runtime via the
# `env_file:` directive in docker-compose.yml. Keep it out of the build
# context so an accidental COPY in a future Dockerfile cannot leak it.
.env
.env.local
.env.*.local
.env.demo

# Build artifacts
**/node_modules
**/dist
**/build
**/coverage
**/*.tsbuildinfo

# VCS
.git
.gitignore
.gitattributes

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db
**/*.swp
**/*.swo

# Logs
**/*.log
**/npm-debug.log*

# Repo-only assets that shouldn't end up in any image
RELATORIO-AUDITORIA-*.md
AUDITORIA_SEGURANCA.md
prompt-auditoria-*.md
README.md
LICENSE
.env.example
GUIA-IMPLANTACAO.md
GUIA-USO.md

# Build helper (lives only on the host — never enters runtime images)
build.sh
Dockerfile.build
.build-cache

# Sensitive
.npmrc
**/.npmrc

# Docker meta
.docker
.dockerignore

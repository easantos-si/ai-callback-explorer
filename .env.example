# =============================================================================
# ai-callback-explorer — environment configuration
# =============================================================================
# Copy this file to `.env` and adjust the values for your deployment.
#
# How values are consumed:
#   - docker-compose: reads this `.env` automatically at compose-time and
#     interpolates `${VAR}` references in docker-compose.yml (used by the
#     frontend build args VITE_API_BASE_URL / VITE_WS_PATH).
#   - backend container: the `.env` is COPY'd into the image at build time
#     and loaded by `node --env-file=.env` at startup. Variables set in the
#     OS environment of the container override values from this file.
#
# IMPORTANT: changing any value here requires a fresh image build:
#     docker-compose build && docker-compose up -d
# =============================================================================

# ---------- Runtime ----------------------------------------------------------
NODE_ENV=production
PORT=3900
LOG_LEVEL=info

# ---------- Public-facing UI origin ------------------------------------------
# CSV of explicit Origin values that the API and Socket.IO accept. Set this
# to the URL the user types in the browser to reach the SPA. An empty value
# rejects all browser CORS requests (intentionally fail-closed — the
# bootstrap will warn).
#
# Examples:
#   UI_ORIGIN=https://callback.example.com
#   UI_ORIGIN=https://callback.example.com,https://staging.example.com
#   UI_ORIGIN=http://localhost:3901
UI_ORIGIN=http://localhost:3901

# Canonical public URL of the SPA (no trailing slash). The frontend
# uses URL_BASE to build:
#   - Callback URLs (so a tampered IndexedDB row can't redirect copy/paste)
#   - Share links generated from the QR-reveal flow
# Empty falls back to window.location.origin in the browser — fine for
# local dev but unsafe behind multiple hosts. Set this whenever you put
# the app behind a real domain.
URL_BASE=http://localhost:3901

# ---------- Origin filtering (CORS allow list) -------------------------------
# Master switch for the CORS allow list. When this is false (default):
#   - The API and WebSocket accept ANY browser Origin.
#   - The Super Mode UI in the SPA is hidden — the 12-press unlock does
#     nothing, and the admin endpoints below return 403 with a clear
#     reason. Managing an allow list nothing consults would be misleading.
#   - All login/JWT protection still applies (see AUTH_ENABLED below).
# When true:
#   - Only origins listed in UI_ORIGIN — plus any added at runtime via the
#     Super Mode panel — are accepted.
#   - Super Mode becomes available, gated by ADMIN_TOKEN.
ORIGIN_FILTERING_ENABLED=false

# ---------- Super Mode admin token -------------------------------------------
# Secret required to manage the allowed-origins list at runtime via the
# hidden "Super Mode" panel in the SPA. Reveal Super Mode by pressing the
# same key 12 times in a row anywhere on the page (outside of inputs), then
# enter this token to authenticate. Origins added at runtime are kept only
# in process memory and reset on container restart — for permanent additions
# update UI_ORIGIN above and rebuild. Leave ADMIN_TOKEN empty to disable
# runtime origin management entirely (Super Mode will reject any token).
ADMIN_TOKEN=

# ---------- Login / TOTP authentication --------------------------------------
# When AUTH_ENABLED=true the SPA renders an anti-bot challenge + TOTP code
# entry before the UI loads. A short-lived JWT is issued on success and
# kept memory-only on the client (sessionStorage at most), so closing the
# tab logs the user out automatically. The /api/callback/* endpoint stays
# completely public — third-party services keep posting callbacks with no
# token. WebSocket and /api/sessions/* require the JWT.
#
# When AUTH_ENABLED=false (default) the login screen is bypassed entirely
# and the app behaves exactly as before — no JWT, no captcha, no QR.
AUTH_ENABLED=false

# Shared TOTP secret. Single secret for the whole app — every operator
# registers it once in their authenticator (Google/Microsoft/etc). Use the
# in-app QR reveal (see MASTER_PASSWORD) to onboard new operators without
# emailing the secret around in plaintext. Rotating this value invalidates
# every existing registration.
# Format: RFC 4648 base32, no padding (uppercase A–Z + 2–7), ≥16 chars.
TOTP_SECRET=

# Master password that gates the QR-reveal flow on the login screen. On the
# login UI, press the same key 12 times to surface a hidden password field
# — entering this value yields the otpauth:// URI rendered as a QR locally
# (the QR pixels never travel the wire). Leave empty to disable QR reveal.
MASTER_PASSWORD=

# Issuer + account label shown by authenticator apps for the TOTP entry.
TOTP_ISSUER=AI Callback Explorer
TOTP_LABEL=admin

# JWT signing secret. Generate ≥32 random bytes:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Empty + AUTH_ENABLED=true logs an error and rejects every login.
JWT_SECRET=

# Access-token lifetime in seconds (60–3600). The SPA refreshes the token
# silently every TTL/3 seconds while the tab is open.
AUTH_TOKEN_TTL_SEC=900

# ---------- Trust proxy ------------------------------------------------------
# CIDRs of every reverse proxy hop in front of the backend (Cloudflare,
# external nginx, docker bridge, loopback). NEVER set to "true" or "*" — the
# bootstrap will warn and downgrade to loopback-only.
#
# Default below covers the docker bridge (where frontend-nginx and
# cloudflared sit) plus loopback. If you front this with an HTTPS nginx on
# the host that runs OUTSIDE docker, append its IP. If you receive traffic
# straight from cloudflared in a sibling container, the docker bridge CIDR
# already covers it.
TRUST_PROXY=172.16.0.0/12,127.0.0.1,::1

# ---------- Body / payload limits --------------------------------------------
# Applies to express body-parsers (json, urlencoded, text, raw) AFTER
# gzip/deflate inflation. Should match `client_max_body_size` in nginx.conf.
MAX_PAYLOAD_SIZE=50mb

# ---------- Session storage --------------------------------------------------
# Path to the SQLite file the backend uses to persist session metadata.
# Mount a Docker volume on the parent directory so the table survives
# image rebuilds and container removals — see docker-compose.yml. Each
# boot, the SessionService deletes any rows past their TTL before
# loading the rest into memory.
SQLITE_PATH=/app/data/sessions.db

# ---------- Session caps -----------------------------------------------------
# TTL after the last activity. Idle sessions expire after this.
SESSION_TTL_HOURS=24

# Window for a session that was created but never received its first
# callback. Lets us evict abandoned sessions quickly.
SESSION_FIRST_USE_GRACE_MIN=60

# Hard cap on the total number of live sessions in memory.
MAX_SESSIONS=50000

# Hard cap on callbacks recorded per session.
MAX_CALLBACKS_PER_SESSION=10000

# Hard cap on cumulative bytes of callback bodies per session.
# Default 200 MB = 209715200 bytes.
MAX_BYTES_PER_SESSION=209715200

# ---------- Frontend build (Vite) --------------------------------------------
# Empty = same-origin (the SPA calls /api on the same host that serves it,
# which is what nginx in front does). Override only for unusual setups.
VITE_API_BASE_URL=
VITE_WS_PATH=/socket.io
